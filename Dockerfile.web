# ---- PracticeOps static site image ----
# Serves the HTML/CSS/JS with nginx. Tiny (~25 MB).
FROM nginx:1.27-alpine

# Custom nginx config (gzip, cache headers, fallback)
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Static site assets
COPY index.html courses.html course.html lab.html /usr/share/nginx/html/
COPY css/  /usr/share/nginx/html/css/
COPY js/   /usr/share/nginx/html/js/

EXPOSE 80

# nginx:alpine already runs `nginx -g 'daemon off;'` as the default CMD.
HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD wget -qO /dev/null http://127.0.0.1/ || exit 1
