//@version=6
// =============================================================================
//  MOMENTUM TRADER PRO  —  V3  (Core + Risk Mgmt + CLEAR TRADE TICKET + Sizing)
//  Platform : TradingView Pine Script v6   |   Market: NSE equities (intraday)
//  Timezone : Asia/Kolkata                 |   Suggested TF: 5 min
//
//  WHAT THIS BUILD SHOWS — the moment a BUY/SELL fires you get, on the chart:
//        Entry  : 1624.00
//        Stop   : 1617.00   (Risk 7.00 / share)
//        Target : 1638.00   (2R)
//        Qty    : 71 shares
//        Risk ₹ : 497
//  ...as a pop-up label on the signal bar AND a persistent "Trade Ticket" panel.
//
//  Includes:  V1 (ORB+VWAP+EMA+Volume+ATR+2R)  ·  V2 (daily risk rules)
//             V3 (dashboard: WinRate, Profit Factor)  ·  V7 (auto position size)
//
//  ENTRY FIX : uses ta.crossover(close, orHigh) — fires only on the breakout
//              candle, so the entry price is always right at the level (no more
//              late entries far above OR High).
//
//  NO-REPAINT: signals on confirmed close, fills next bar open, no lookahead.
// =============================================================================

strategy(
     title              = "Momentum Trader Pro V3",
     shorttitle         = "MTP v3",
     overlay            = true,
     pyramiding         = 0,
     initial_capital    = 100000,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.03,
     slippage           = 2,
     calc_on_every_tick = false,
     process_orders_on_close = false)

// -----------------------------------------------------------------------------
//  INPUTS
// -----------------------------------------------------------------------------
tz = "Asia/Kolkata"

grpOR   = "Opening Range"
orStart = input.session("0915-0930", "OR window (build)", group = grpOR)

grpTr   = "Trend / VWAP"
emaFastLen = input.int(20, "EMA Fast", minval = 1, group = grpTr)
emaSlowLen = input.int(50, "EMA Slow", minval = 1, group = grpTr)
useVwap    = input.bool(true, "Require VWAP alignment", group = grpTr)
useEma     = input.bool(true, "Require EMA20/50 alignment", group = grpTr)

grpVol  = "Volume Spike"
useVol  = input.bool(true, "Require volume spike", group = grpVol)
volLen  = input.int(20, "Volume avg length", minval = 1, group = grpVol)
volMult = input.float(1.5, "Volume multiplier (RelVol)", minval = 1.0, step = 0.1, group = grpVol)

grpRisk = "Risk / Exits"
atrLen  = input.int(14, "ATR length", minval = 1, group = grpRisk)
atrMult = input.float(1.5, "ATR stop multiplier", minval = 0.1, step = 0.1, group = grpRisk)
rrMult  = input.float(2.0, "Reward:Risk (target)", minval = 0.5, step = 0.5, group = grpRisk)

grpDir  = "Direction"
allowLongs  = input.bool(true, "Allow Longs", group = grpDir)
allowShorts = input.bool(true, "Allow Shorts", group = grpDir)

grpMM        = "Risk Management (V2)"
maxTrades    = input.int(2, "Max trades / day", minval = 1, group = grpMM)
dailyLoss    = input.float(2000, "Daily loss limit (₹)",   minval = 0, step = 100, group = grpMM)
dailyProfit  = input.float(3000, "Daily profit limit (₹)", minval = 0, step = 100, group = grpMM)
closeOnLimit = input.bool(true, "Close open trade when a daily limit is hit", group = grpMM)
noNewAfter   = input.session("0930-1430", "New-entry window", group = grpMM)
forceExitStr = input.session("1520-1525", "Force-exit window", group = grpMM)

// ---- V7 : Position Sizing --------------------------------------------------
grpPS    = "Position Sizing (V7)"
capital  = input.float(100000, "Capital (₹)",        minval = 0, step = 1000, group = grpPS)
riskPct  = input.float(0.5,    "Risk per trade (%)", minval = 0.01, step = 0.1, group = grpPS,
             tooltip = "Quantity is sized so that (Entry−Stop) × Qty ≈ this % of capital.")
tickSize = input.float(0.05,   "Tick size (₹)",      minval = 0.01, step = 0.01, group = grpPS,
             tooltip = "NSE equities are usually ₹0.05. Stops/targets are rounded to this.")
useCalcQty = input.bool(true, "Size backtest orders by calculated Qty", group = grpPS)

// -----------------------------------------------------------------------------
//  HELPERS
// -----------------------------------------------------------------------------
roundTick(p) => math.round(p / tickSize) * tickSize

// -----------------------------------------------------------------------------
//  INDICATORS
// -----------------------------------------------------------------------------
emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)
vwap    = ta.vwap
atr     = ta.atr(atrLen)
volAvg  = ta.sma(volume, volLen)
rvol    = volAvg > 0 ? volume / volAvg : 0.0

// -----------------------------------------------------------------------------
//  SESSION / OPENING RANGE
// -----------------------------------------------------------------------------
inOR    = not na(time(timeframe.period, orStart, tz))
newDay  = ta.change(time("D")) != 0

var float orHigh   = na
var float orLow    = na
var bool  orReady  = false

if newDay
    orHigh  := na
    orLow   := na
    orReady := false

if inOR
    orHigh := na(orHigh) ? high : math.max(orHigh, high)
    orLow  := na(orLow)  ? low  : math.min(orLow, low)

if (not inOR) and (not na(orHigh)) and (not orReady) and (not newDay)
    orReady := true

// -----------------------------------------------------------------------------
//  DAILY STATE (V2)
// -----------------------------------------------------------------------------
var int   tradesToday   = 0
var float dayStartNet   = 0.0
var bool  limitHitToday = false

if newDay
    tradesToday   := 0
    dayStartNet   := strategy.netprofit
    limitHitToday := false

dailyPnL  = (strategy.netprofit - dayStartNet) + strategy.openprofit
lossHit   = dailyLoss   > 0 and dailyPnL <= -dailyLoss
profitHit = dailyProfit > 0 and dailyPnL >=  dailyProfit
if lossHit or profitHit
    limitHitToday := true

inEntryWindow = not na(time(timeframe.period, noNewAfter,   tz))
inForceExit   = not na(time(timeframe.period, forceExitStr, tz))

// -----------------------------------------------------------------------------
//  FILTERS
// -----------------------------------------------------------------------------
trendUp  = (not useEma)  or (emaFast > emaSlow)
trendDn  = (not useEma)  or (emaFast < emaSlow)
vwapUp   = (not useVwap) or (close > vwap)
vwapDn   = (not useVwap) or (close < vwap)
volSpike = (not useVol)  or (volume > volAvg * volMult)

afterOR  = orReady and (not inOR)
isFlat   = strategy.position_size == 0
canTrade = afterOR and isFlat and inEntryWindow and (not inForceExit) and
           (tradesToday < maxTrades) and (not limitHitToday)

// -----------------------------------------------------------------------------
//  ENTRY TRIGGERS  (crossover = the breakout candle only)
// -----------------------------------------------------------------------------
breakoutUp = ta.crossover(close, orHigh)
breakoutDn = ta.crossunder(close, orLow)

longSignal  = allowLongs  and canTrade and breakoutUp and trendUp and vwapUp and volSpike
shortSignal = allowShorts and canTrade and breakoutDn and trendDn and vwapDn and volSpike

// -----------------------------------------------------------------------------
//  TRADE TICKET  (entry / stop / target / risk-per-share / quantity / ₹ risk)
//  Persisted in var's so the ticket panel keeps showing the live trade.
// -----------------------------------------------------------------------------
var string tSide   = "—"
var float  tEntry  = na
var float  tStop   = na
var float  tTgt    = na
var float  tRisk   = na      // risk per share (₹)
var int    tQty    = 0
var float  tRiskRs = na      // total ₹ at risk = tRisk * tQty

sizeQty(riskPerShare) =>
    riskPerShare > 0 ? math.floor((capital * riskPct / 100.0) / riskPerShare) : 0

// ---- LONG ------------------------------------------------------------------
if longSignal
    entry = close
    stop  = roundTick(close - atr * atrMult)
    risk  = entry - stop
    qty   = sizeQty(risk)
    if qty >= 1
        tgt = roundTick(entry + risk * rrMult)
        tSide   := "BUY"
        tEntry  := entry
        tStop   := stop
        tTgt    := tgt
        tRisk   := risk
        tQty    := qty
        tRiskRs := risk * qty
        tradesToday += 1
        strategy.entry("Long", strategy.long, qty = useCalcQty ? qty : na)
        strategy.exit("L-exit", from_entry = "Long", stop = stop, limit = tgt)

// ---- SHORT -----------------------------------------------------------------
if shortSignal
    entry = close
    stop  = roundTick(close + atr * atrMult)
    risk  = stop - entry
    qty   = sizeQty(risk)
    if qty >= 1
        tgt = roundTick(entry - risk * rrMult)
        tSide   := "SELL"
        tEntry  := entry
        tStop   := stop
        tTgt    := tgt
        tRisk   := risk
        tQty    := qty
        tRiskRs := risk * qty
        tradesToday += 1
        strategy.entry("Short", strategy.short, qty = useCalcQty ? qty : na)
        strategy.exit("S-exit", from_entry = "Short", stop = stop, limit = tgt)

// ---- forced / limit exits (V2) ---------------------------------------------
if inForceExit and strategy.position_size != 0
    strategy.close_all(comment = "EOD 15:20")
if limitHitToday and closeOnLimit and strategy.position_size != 0
    strategy.close_all(comment = lossHit ? "Daily loss limit" : "Daily profit limit")

// -----------------------------------------------------------------------------
//  POP-UP TICKET LABEL on the signal bar  + ALERT (V4 preview)
// -----------------------------------------------------------------------------
f2(x) => str.tostring(x, "#.##")
buildTicket(side) =>
    side + " " + syminfo.ticker +
      "\nEntry : " + f2(tEntry) +
      "\nStop  : " + f2(tStop) + "  (" + f2(tRisk) + "/sh)" +
      "\nTgt   : " + f2(tTgt) + "  (" + f2(rrMult) + "R)" +
      "\nQty   : " + str.tostring(tQty) +
      "\nRisk  : ₹" + f2(tRiskRs)

if longSignal and tSide == "BUY" and tQty >= 1
    label.new(bar_index, low, buildTicket("🟢 BUY"),
         style = label.style_label_up, color = color.new(color.green, 0),
         textcolor = color.white, size = size.normal)
    alert(buildTicket("BUY"), alert.freq_once_per_bar_close)

if shortSignal and tSide == "SELL" and tQty >= 1
    label.new(bar_index, high, buildTicket("🔴 SELL"),
         style = label.style_label_down, color = color.new(color.red, 0),
         textcolor = color.white, size = size.normal)
    alert(buildTicket("SELL"), alert.freq_once_per_bar_close)

// -----------------------------------------------------------------------------
//  PLOTS
// -----------------------------------------------------------------------------
plot(emaFast, "EMA20", color = color.new(color.orange, 0), linewidth = 1)
plot(emaSlow, "EMA50", color = color.new(color.blue, 0),   linewidth = 1)
plot(vwap,    "VWAP",  color = color.new(color.fuchsia, 0), linewidth = 2)
plot(orReady or inOR ? orHigh : na, "OR High", color = color.new(color.teal, 0), style = plot.style_linebr)
plot(orReady or inOR ? orLow  : na, "OR Low",  color = color.new(color.red, 0),  style = plot.style_linebr)
bgcolor(inOR ? color.new(color.gray, 88) : na, title = "OR window")
bgcolor(limitHitToday ? color.new(color.red, 90) : na, title = "Day halted")

// Draw live stop (red) & target (green) lines while in a trade
inTrade = strategy.position_size != 0
plot(inTrade ? tStop : na, "Live Stop",   color = color.new(color.red, 0),   style = plot.style_linebr, linewidth = 1)
plot(inTrade ? tTgt  : na, "Live Target", color = color.new(color.green, 0), style = plot.style_linebr, linewidth = 1)

// -----------------------------------------------------------------------------
//  DASHBOARD  (top-right)  — V3
// -----------------------------------------------------------------------------
wr = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0.0
pf = strategy.grossloss > 0 ? strategy.grossprofit / strategy.grossloss : na

var table dash = table.new(position.top_right, 2, 8, border_width = 1)
if barstate.islast
    hd = color.new(color.gray, 20)
    bd = color.new(color.black, 20)
    plCol = dailyPnL >= 0 ? color.lime : color.red
    table.cell(dash, 0, 0, "Momentum Trader Pro", text_color = color.white, bgcolor = color.new(color.blue, 20))
    table.cell(dash, 1, 0, "V3", text_color = color.white, bgcolor = color.new(color.blue, 20))
    table.cell(dash, 0, 1, "Trend",  text_color = color.white, bgcolor = hd)
    table.cell(dash, 1, 1, emaFast > emaSlow ? "Bullish" : "Bearish", text_color = emaFast > emaSlow ? color.lime : color.red, bgcolor = bd)
    table.cell(dash, 0, 2, "VWAP",   text_color = color.white, bgcolor = hd)
    table.cell(dash, 1, 2, close > vwap ? "Above" : "Below", text_color = close > vwap ? color.lime : color.red, bgcolor = bd)
    table.cell(dash, 0, 3, "RelVol", text_color = color.white, bgcolor = hd)
    table.cell(dash, 1, 3, f2(rvol) + "x", text_color = color.white, bgcolor = bd)
    table.cell(dash, 0, 4, "Today's Trades", text_color = color.white, bgcolor = hd)
    table.cell(dash, 1, 4, str.tostring(tradesToday) + " / " + str.tostring(maxTrades), text_color = color.white, bgcolor = bd)
    table.cell(dash, 0, 5, "Today's P/L", text_color = color.white, bgcolor = hd)
    table.cell(dash, 1, 5, "₹" + f2(dailyPnL), text_color = plCol, bgcolor = bd)
    table.cell(dash, 0, 6, "Win Rate", text_color = color.white, bgcolor = hd)
    table.cell(dash, 1, 6, f2(wr) + "%", text_color = color.white, bgcolor = bd)
    table.cell(dash, 0, 7, "Profit Factor", text_color = color.white, bgcolor = hd)
    table.cell(dash, 1, 7, na(pf) ? "—" : f2(pf), text_color = na(pf) ? color.gray : (pf >= 1 ? color.lime : color.red), bgcolor = bd)

// -----------------------------------------------------------------------------
//  TRADE TICKET PANEL  (bottom-right)  — the "clear entry with all details"
// -----------------------------------------------------------------------------
var table tkt = table.new(position.bottom_right, 2, 7, border_width = 1)
if barstate.islast
    sideCol = tSide == "BUY" ? color.new(color.green, 15) : tSide == "SELL" ? color.new(color.red, 15) : color.new(color.gray, 30)
    hd2 = color.new(color.gray, 20)
    bd2 = color.new(color.black, 20)
    stat = strategy.position_size > 0 ? "IN LONG" : strategy.position_size < 0 ? "IN SHORT" : "FLAT / last signal"
    table.cell(tkt, 0, 0, "TRADE TICKET", text_color = color.white, bgcolor = sideCol)
    table.cell(tkt, 1, 0, tSide, text_color = color.white, bgcolor = sideCol)
    table.cell(tkt, 0, 1, "Entry", text_color = color.white, bgcolor = hd2)
    table.cell(tkt, 1, 1, na(tEntry) ? "—" : f2(tEntry), text_color = color.white, bgcolor = bd2)
    table.cell(tkt, 0, 2, "Stop Loss", text_color = color.white, bgcolor = hd2)
    table.cell(tkt, 1, 2, na(tStop) ? "—" : f2(tStop), text_color = color.red, bgcolor = bd2)
    table.cell(tkt, 0, 3, "Target", text_color = color.white, bgcolor = hd2)
    table.cell(tkt, 1, 3, na(tTgt) ? "—" : f2(tTgt), text_color = color.lime, bgcolor = bd2)
    table.cell(tkt, 0, 4, "Risk / share", text_color = color.white, bgcolor = hd2)
    table.cell(tkt, 1, 4, na(tRisk) ? "—" : "₹" + f2(tRisk), text_color = color.white, bgcolor = bd2)
    table.cell(tkt, 0, 5, "Quantity", text_color = color.white, bgcolor = hd2)
    table.cell(tkt, 1, 5, tQty < 1 ? "—" : str.tostring(tQty), text_color = color.yellow, bgcolor = bd2)
    table.cell(tkt, 0, 6, "Total Risk", text_color = color.white, bgcolor = hd2)
    table.cell(tkt, 1, 6, na(tRiskRs) ? "—" : "₹" + f2(tRiskRs) + "  (" + stat + ")", text_color = color.white, bgcolor = bd2)
